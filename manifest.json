{
  "manifest_version": 3,
  "name": "Socialnamer",
  "version": "0.2.1",
  "description": "Save images from X and Bluesky with a smart filename from the post: poster, handle, artist, tags. Convert WebP to PNG or JPG.",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Download with Socialnamer",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "contextMenus",
    "downloads"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://bsky.app/*",
    "https://*.twimg.com/*",
    "https://*.bsky.app/*",
    "https://pawoo.net/*",
    "https://*.pawoo.net/*",
    "https://baraag.net/*",
    "https://*.baraag.net/*",
    "https://plc.directory/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://bsky.app/*",
        "https://pawoo.net/*",
        "https://baraag.net/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}