{
  "manifest_version": 3,
  "name": "Smart Image Saver",
  "version": "0.1.0",
  "description": "Adds a 'Save image as (smart name)' item that opens the Save As dialog pre-filled with the poster, handle, artist credit, and tags from the post.",

  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  "action": {
    "default_title": "Save Image w Custom Filename",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },

  "permissions": [
    "contextMenus",
    "downloads"
  ],

  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://bsky.app/*",
    "https://*.twimg.com/*",
    "https://*.bsky.app/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://bsky.app/*"
      ],
      "js": ["extractors.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
